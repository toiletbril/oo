#!/bin/sh
# Verify that --dns rejects values that are not valid IP addresses. A crafted
# value with a newline must not sneak extra lines into resolv.conf.

NS="di"

cleanup() { "$BIN" $FLAGS down "$NS" || true; }
"$BIN" $FLAGS down "$NS" || true
trap cleanup EXIT

if "$BIN" $FLAGS up "$NS" --dns "1.1.1.1
malicious=line" -- sleep 1; then
  echo "accepted malicious dns: FAILED"
else
  echo "rejected malicious dns: ok"
fi
