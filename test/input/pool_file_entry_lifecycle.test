#!/bin/sh
# Verify that the shared IP pool file records an entry as <subnet>=<ns_name>
# while the namespace is up, and that the entry is removed on down.

NS="ps"
POOL="/var/run/oo/ip-pool.ini"

cleanup() { "$BIN" $FLAGS down "$NS" || true; }
"$BIN" $FLAGS down "$NS" || true
trap cleanup EXIT

"$BIN" $FLAGS up "$NS" -- sleep 3

OCTET=$(grep '^subnet_octet=' "/var/run/oo/$NS/network.ini" | cut -d= -f2)
EXPECTED="10.0.${OCTET}.0/30=${NS}"

if grep -qx "$EXPECTED" "$POOL"; then
  echo "pool entry on up: ok"
else
  echo "pool entry on up: FAILED (expected '$EXPECTED')"
fi

"$BIN" $FLAGS down "$NS"
sleep 1

if grep -qx "$EXPECTED" "$POOL"; then
  echo "pool entry on down: FAILED (still present)"
else
  echo "pool entry on down: ok"
fi
