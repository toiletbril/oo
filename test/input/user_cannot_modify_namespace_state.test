#!/bin/sh
# Verify that the invoking user can READ namespace state but cannot
# modify it. The refactor removed CAP_DAC_OVERRIDE; files under
# /var/run/oo/<ns> are oorunner-owned 0644 and the parent dir is 0755.

NS="rw"

cleanup() { ../oo down "$NS" 2>/dev/null || true; }
../oo down "$NS" 2>/dev/null || true
trap cleanup EXIT

../oo up "$NS" -- sleep 3 2>/dev/null

PIDS="/var/run/oo/$NS/pids.ini"

if cat "$PIDS" >/dev/null 2>&1; then
  echo "user reads pids.ini (ok)"
else
  echo "user reads pids.ini: denied (FAILED)"
fi

if { echo hi >> "$PIDS"; } 2>/dev/null; then
  echo "user writes pids.ini: allowed (FAILED)"
else
  echo "user writes pids.ini: denied (ok)"
fi

if { touch "/var/run/oo/$NS/evil"; } 2>/dev/null; then
  echo "user creates file in ns dir: allowed (FAILED)"
else
  echo "user creates file in ns dir: denied (ok)"
fi

if { touch "/var/run/oo/evil"; } 2>/dev/null; then
  echo "user creates file in runtime dir: allowed (FAILED)"
else
  echo "user creates file in runtime dir: denied (ok)"
fi
