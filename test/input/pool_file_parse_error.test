#!/bin/sh
# Verify that the ini parser rejects malformed entries in the shared pool
# file and that oo up surfaces a clear error instead of silently allocating.

NS="pc"
POOL="/var/run/oo/ip-pool.ini"

cleanup() {
  ../oo down "$NS" 2>/dev/null || true
  # Reset pool file to a clean state so later tests still run.
  printf '# IP Pool allocation state\n# Format: <subnet>=<namespace_name>\n' \
    > "$POOL" 2>/dev/null || true
}
../oo down "$NS" 2>/dev/null || true
trap cleanup EXIT

# Materialise the pool file with a valid header.
../oo up "$NS" -- sleep 1 2>/dev/null
../oo down "$NS" 2>/dev/null

# Append a line missing the '=' separator.
printf 'no-equals-sign\n' >> "$POOL"

../oo up "$NS" -- sleep 1 2>&1 | head -n 1

# Reset and try a broken section header.
printf '# IP Pool allocation state\n# Format: <subnet>=<namespace_name>\n[unclosed\n' \
  > "$POOL"

../oo up "$NS" -- sleep 1 2>&1 | head -n 1
