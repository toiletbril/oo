#!/bin/sh
# Verify that oo up creates a veth pair: one end on the host,
# one end inside the namespace.

NS="ic"

cleanup() { ../oo down "$NS" 2>/dev/null || true; }
../oo down "$NS" 2>/dev/null || true
trap cleanup EXIT

../oo up "$NS" -- sleep 3 2>/dev/null

if ip link show "veth-${NS}-host" >/dev/null 2>&1; then
  echo "host veth veth-${NS}-host: ok"
else
  echo "host veth veth-${NS}-host: FAILED"
fi

if ../oo exec "$NS" -- ip link show "veth-${NS}-ns" >/dev/null 2>&1; then
  echo "ns veth veth-${NS}-ns: ok"
else
  echo "ns veth veth-${NS}-ns: FAILED"
fi
