#!/bin/sh
# Verify that oo up creates a veth pair: one end on the host,
# one end inside the namespace.

NS="ic"

cleanup() { "$BIN" $FLAGS down "$NS" || true; }
"$BIN" $FLAGS down "$NS" || true
trap cleanup EXIT

"$BIN" $FLAGS up "$NS" -- sleep 3

if ip link show "veth-${NS}-host" >/dev/null; then
  echo "host veth veth-${NS}-host: ok"
else
  echo "host veth veth-${NS}-host: FAILED"
fi

if "$BIN" $FLAGS exec "$NS" -- ip link show "veth-${NS}-ns" >/dev/null; then
  echo "ns veth veth-${NS}-ns: ok"
else
  echo "ns veth veth-${NS}-ns: FAILED"
fi
