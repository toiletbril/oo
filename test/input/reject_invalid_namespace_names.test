#!/bin/sh
# Verify that invalid namespace names are rejected. Errors go to stderr
# (captured to trace.log by the Makefile); each case prints an ok/FAILED
# line to stdout based on exit status.

check_rejected() {
  label=$1
  shift
  if "$BIN" $FLAGS up "$@"; then
    echo "$label: accepted (FAILED)"
  else
    echo "$label: rejected (ok)"
  fi
}

# Name longer than MAX_NS_NAME_LEN=5.
check_rejected "toolong" "toolong" -- sleep 0

# Slash in name (path traversal).
check_rejected "slash"   "fo/o"    -- sleep 0

# Invalid character.
check_rejected "invalid" "fo!o"    -- sleep 0

# Empty name.
check_rejected "empty"   ""        -- sleep 0
