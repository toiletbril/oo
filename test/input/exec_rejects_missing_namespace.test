#!/bin/sh
# Verify that `oo exec` on a namespace that was never up produces a clean
# error rather than crashing or entering an undefined state.

NS="nope"

"$BIN" $FLAGS down "$NS" || true

if "$BIN" $FLAGS exec "$NS" -- /bin/true; then
  echo "exec on missing namespace: accepted (FAILED)"
else
  echo "exec on missing namespace: rejected (ok)"
fi
