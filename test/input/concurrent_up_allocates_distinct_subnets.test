#!/bin/sh
# Verify that two concurrent oo up invocations allocate distinct subnets.
# This exercises the fcntl file lock on ip-pool.ini.

NS1="sr1"
NS2="sr2"

cleanup() {
  "$BIN" $FLAGS down "$NS1" || true
  "$BIN" $FLAGS down "$NS2" || true
}
"$BIN" $FLAGS down "$NS1" || true
"$BIN" $FLAGS down "$NS2" || true
trap cleanup EXIT

"$BIN" $FLAGS up "$NS1" -- sleep 2 &
"$BIN" $FLAGS up "$NS2" -- sleep 2 &
wait

SUB1=$(grep '^subnet_octet=' "/var/run/oo/$NS1/network.ini" | cut -d= -f2)
SUB2=$(grep '^subnet_octet=' "/var/run/oo/$NS2/network.ini" | cut -d= -f2)

if test -n "$SUB1" && test -n "$SUB2" && test "$SUB1" != "$SUB2"; then
  echo "ns1 and ns2 have distinct subnets: ok"
else
  echo "ns1 subnet=$SUB1 ns2 subnet=$SUB2 (FAILED)"
fi
