#!/bin/sh
# Verify that two concurrent oo up invocations allocate distinct subnets.
# This exercises the fcntl file lock on ip-pool.ini.

NS1="sr1"
NS2="sr2"

cleanup() {
  ../oo down "$NS1" 2>/dev/null || true
  ../oo down "$NS2" 2>/dev/null || true
}
../oo down "$NS1" 2>/dev/null || true
../oo down "$NS2" 2>/dev/null || true
trap cleanup EXIT

../oo up "$NS1" -- sleep 30 2>/dev/null &
../oo up "$NS2" -- sleep 30 2>/dev/null &
wait

SUB1=$(grep '^subnet_octet=' "/var/run/oo/$NS1/network.ini" 2>/dev/null | cut -d= -f2)
SUB2=$(grep '^subnet_octet=' "/var/run/oo/$NS2/network.ini" 2>/dev/null | cut -d= -f2)

if test -n "$SUB1" && test -n "$SUB2" && test "$SUB1" != "$SUB2"; then
  echo "ns1 and ns2 have distinct subnets: ok"
else
  echo "ns1 subnet=$SUB1 ns2 subnet=$SUB2 (FAILED)"
fi
