#!/bin/sh
# Verify that `oo up` refuses to start a second daemon when one is already
# running in the same namespace. Covers the living-daemon branch in up.cc.

NS="du"

cleanup() { "$BIN" $FLAGS down "$NS" || true; }
"$BIN" $FLAGS down "$NS" || true
trap cleanup EXIT

"$BIN" $FLAGS up "$NS" -- sleep 3

if "$BIN" $FLAGS up "$NS" -- sleep 3; then
  echo "second up: accepted (FAILED)"
else
  echo "second up: rejected (ok)"
fi
