#!/bin/sh
# Verify that /var/run/oo is 0755 (not world-writable) and that each
# namespace directory is created 0755 (owner write, others read-only).
# The owner is the 'oorunner' system user, so the invoking user can read
# namespace state but cannot modify it.

NS="dp"

cleanup() { "$BIN" $FLAGS down "$NS" || true; }
"$BIN" $FLAGS down "$NS" || true
trap cleanup EXIT

PARENT_PERMS=$(stat -c '%a' /var/run/oo)
if test "$PARENT_PERMS" = "755"; then
  echo "/var/run/oo perms: 755 (ok)"
else
  echo "/var/run/oo perms: $PARENT_PERMS (FAILED)"
fi

"$BIN" $FLAGS up "$NS" -- sleep 3

NS_PERMS=$(stat -c '%a' "/var/run/oo/$NS")
if test "$NS_PERMS" = "755"; then
  echo "namespace dir perms: 755 (ok)"
else
  echo "namespace dir perms: $NS_PERMS (FAILED)"
fi
